{
  "manifest_version": 3,
  "name": "Broc",
  "version": "0.1.0",
  "description": "AI agent browser control via native messaging",
  "browser_specific_settings": {
    "gecko": {
      "id": "broc@anthropic.ai",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "nativeMessaging",
    "webNavigation"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_title": "Broc Canvas"
  }
}
