{
  "manifest_version": 3,
  "name": "Broc",
  "version": "0.1.0",
  "description": "AI agent browser control via native messaging",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "nativeMessaging",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
